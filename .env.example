# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/doer

# ── GitHub OAuth App ──────────────────────────────────────
# 1. Go to github.com/settings/developers → OAuth Apps → New OAuth App
# 2. Set callback URL to: http://localhost:3000/api/auth/github/callback
#    (or your deployed APP_URL + /api/auth/github/callback)
# 3. Paste Client ID and Secret below
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_BASE_BRANCH=main

# ── AI Model (OpenAI-compatible) ──────────────────────────
AI_API_KEY=
AI_BASE_URL=                           # blank = OpenAI | https://openrouter.ai/api/v1 | https://your.openai.azure.com
AI_MODEL=gpt-4o                        # any model your provider supports

# ── App ───────────────────────────────────────────────────
APP_URL=http://localhost:3000          # update to your deployed URL in production
CRON_SECRET=change-me
SCHEDULER_CRON=*/10 * * * *

# ── Docker ────────────────────────────────────────────────
DOCKER_NETWORK=doer
AGENT_IMAGE=doer-agent
